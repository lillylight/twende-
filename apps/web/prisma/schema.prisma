generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  PASSENGER
  DRIVER
  OPERATOR_ADMIN
  RTSA_OFFICIAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  AIRTEL_MONEY
  MTN_MOMO
  ZAMTEL_KWACHA
  PAY_AT_TERMINAL
}

enum JourneyStatus {
  SCHEDULED
  BOARDING
  EN_ROUTE
  COMPLETED
  CANCELLED
}

enum AlertType {
  SPEEDING
  ROUTE_DEVIATION
  NO_SIGNAL
  OVERDUE
  SOS
}

enum AlertSeverity {
  WARNING
  CRITICAL
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  phone        String   @unique @db.VarChar(20)
  name         String   @db.VarChar(100)
  email        String?  @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(PASSENGER)
  nrc          String?  @db.VarChar(20)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  driver    Driver?
  bookings  Booking[]
  ratings   Rating[]
  sosEvents SOSEvent[]

  @@index([role])
  @@index([phone])
  @@map("users")
}

model Operator {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(150)
  rtsaLicenceNumber String   @unique @map("rtsa_licence_number") @db.VarChar(50)
  licenceExpiry     DateTime @map("licence_expiry")
  contactPhone      String   @map("contact_phone") @db.VarChar(20)
  contactEmail      String?  @map("contact_email") @db.VarChar(150)
  complianceScore   Decimal  @default(5.0) @map("compliance_score") @db.Decimal(3, 1)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  drivers  Driver[]
  journeys Journey[]
  alerts   SafetyAlert[]

  @@index([rtsaLicenceNumber])
  @@map("operators")
}

model Driver {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  operatorId    String   @map("operator_id") @db.Uuid
  licenceNumber String   @map("licence_number") @db.VarChar(50)
  licenceExpiry DateTime @map("licence_expiry")
  rating        Decimal  @default(5.0) @db.Decimal(2, 1)
  totalTrips    Int      @default(0) @map("total_trips")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  journeys Journey[]
  ratings  Rating[]

  @@index([operatorId])
  @@index([userId])
  @@map("drivers")
}

model Route {
  id                       String   @id @default(uuid()) @db.Uuid
  fromCity                 String   @map("from_city") @db.VarChar(100)
  toCity                   String   @map("to_city") @db.VarChar(100)
  distanceKm               Int      @map("distance_km")
  estimatedDurationMinutes Int      @map("estimated_duration_minutes")
  waypoints                Json?    @default("[]")
  isActive                 Boolean  @default(true) @map("is_active")
  createdAt                DateTime @default(now()) @map("created_at")

  journeys Journey[]

  @@index([fromCity, toCity])
  @@map("routes")
}

model Journey {
  id              String        @id @default(uuid()) @db.Uuid
  routeId         String        @map("route_id") @db.Uuid
  operatorId      String        @map("operator_id") @db.Uuid
  driverId        String        @map("driver_id") @db.Uuid
  busRegistration String        @map("bus_registration") @db.VarChar(20)
  departureTime   DateTime      @map("departure_time")
  arrivalTime     DateTime?     @map("arrival_time")
  totalSeats      Int           @map("total_seats")
  availableSeats  Int           @map("available_seats")
  price           Decimal       @db.Decimal(10, 2)
  status          JourneyStatus @default(SCHEDULED)
  trackingToken   String        @unique @map("tracking_token") @db.VarChar(64)
  createdAt       DateTime      @default(now()) @map("created_at")

  route    Route    @relation(fields: [routeId], references: [id], onDelete: Restrict)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  driver   Driver   @relation(fields: [driverId], references: [id], onDelete: Restrict)

  bookings  Booking[]
  gpsLogs   GPSLog[]
  alerts    SafetyAlert[]
  sosEvents SOSEvent[]

  @@index([routeId])
  @@index([operatorId])
  @@index([driverId])
  @@index([departureTime])
  @@index([status])
  @@map("journeys")
}

model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  journeyId      String        @map("journey_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  seatNumber     Int?          @map("seat_number")
  reference      String        @unique @db.VarChar(20)
  paymentMethod  PaymentMethod @map("payment_method")
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  status         BookingStatus @default(PENDING)
  price          Decimal       @db.Decimal(10, 2)
  bookedVia      String        @default("WEB") @map("booked_via") @db.VarChar(20)
  passengerPhone String        @map("passenger_phone") @db.VarChar(20)
  passengerName  String        @map("passenger_name") @db.VarChar(100)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating  Rating?

  @@index([journeyId])
  @@index([userId])
  @@index([reference])
  @@index([paymentStatus])
  @@map("bookings")
}

model GPSLog {
  id        BigInt   @id @default(autoincrement())
  journeyId String   @map("journey_id") @db.Uuid
  lat       Decimal  @db.Decimal(10, 7)
  lng       Decimal  @db.Decimal(10, 7)
  speedKmh  Int      @map("speed_kmh")
  heading   Int
  accuracy  Decimal  @db.Decimal(6, 2)
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId, timestamp(sort: Desc)])
  @@map("gps_logs")
}

model SafetyAlert {
  id         String        @id @default(uuid()) @db.Uuid
  journeyId  String        @map("journey_id") @db.Uuid
  operatorId String        @map("operator_id") @db.Uuid
  alertType  AlertType     @map("alert_type")
  severity   AlertSeverity
  data       Json          @default("{}")
  resolved   Boolean       @default(false)
  resolvedAt DateTime?     @map("resolved_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  journey  Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([operatorId])
  @@index([alertType])
  @@index([resolved])
  @@map("safety_alerts")
}

model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  driverId  String   @map("driver_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  stars     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([userId])
  @@map("ratings")
}

model SOSEvent {
  id         String    @id @default(uuid()) @db.Uuid
  journeyId  String    @map("journey_id") @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  phone      String    @db.VarChar(20)
  lat        Decimal?  @db.Decimal(10, 7)
  lng        Decimal?  @db.Decimal(10, 7)
  resolved   Boolean   @default(false)
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([journeyId])
  @@index([resolved])
  @@map("sos_events")
}
