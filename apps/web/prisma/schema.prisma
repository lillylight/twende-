generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  PASSENGER
  DRIVER
  OPERATOR_ADMIN
  RTSA_OFFICIAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  PAYMENT_FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  AIRTEL_MONEY
  MTN_MOMO
  ZAMTEL_KWACHA
  PAY_AT_TERMINAL
}

enum JourneyStatus {
  SCHEDULED
  BOARDING
  EN_ROUTE
  COMPLETED
  CANCELLED
}

enum AlertType {
  SPEEDING
  ROUTE_DEVIATION
  NO_SIGNAL
  OVERDUE
  SOS
}

enum AlertSeverity {
  WARNING
  CRITICAL
}

enum SOSStatus {
  ACTIVE
  ACKNOWLEDGED
  RESPONDING
  RESOLVED
  FALSE_ALARM
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  phone        String   @unique @db.VarChar(20)
  name         String   @db.VarChar(100)
  email        String?  @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(PASSENGER)
  nrc          String?  @db.VarChar(20)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  driver                  Driver?
  bookings                Booking[]
  ratings                 Rating[]
  sosEvents               SOSEvent[]
  emergencyContacts       EmergencyContact[]
  notificationPreference  NotificationPreference?

  @@index([role])
  @@index([phone])
  @@map("users")
}

model Operator {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(150)
  rtsaLicenceNumber String   @unique @map("rtsa_licence_number") @db.VarChar(50)
  licenceExpiry     DateTime @map("licence_expiry")
  contactPhone      String   @map("contact_phone") @db.VarChar(20)
  contactEmail      String?  @map("contact_email") @db.VarChar(150)
  complianceScore   Decimal  @default(5.0) @map("compliance_score") @db.Decimal(3, 1)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  drivers    Driver[]
  vehicles   Vehicle[]
  journeys   Journey[]
  alerts     SafetyAlert[]
  promoCodes PromoCode[]

  @@index([rtsaLicenceNumber])
  @@map("operators")
}

model Driver {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  operatorId    String   @map("operator_id") @db.Uuid
  licenceNumber String   @map("licence_number") @db.VarChar(50)
  licenceExpiry DateTime @map("licence_expiry")
  rating        Decimal  @default(5.0) @db.Decimal(2, 1)
  totalTrips    Int      @default(0) @map("total_trips")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  journeys Journey[]
  ratings  Rating[]

  @@index([operatorId])
  @@index([userId])
  @@map("drivers")
}

model Route {
  id                       String   @id @default(uuid()) @db.Uuid
  fromCity                 String   @map("from_city") @db.VarChar(100)
  toCity                   String   @map("to_city") @db.VarChar(100)
  distanceKm               Int      @map("distance_km")
  estimatedDurationMinutes Int      @map("estimated_duration_minutes")
  waypoints                Json?    @default("[]")
  isActive                 Boolean  @default(true) @map("is_active")
  createdAt                DateTime @default(now()) @map("created_at")

  journeys Journey[]

  @@index([fromCity, toCity])
  @@map("routes")
}

model Vehicle {
  id                     String    @id @default(uuid()) @db.Uuid
  registrationNumber     String    @unique @map("registration_number") @db.VarChar(20)
  operatorId             String    @map("operator_id") @db.Uuid
  capacity               Int
  vehicleType            String    @default("BUS") @map("vehicle_type") @db.VarChar(30)
  isWheelchairAccessible Boolean   @default(false) @map("is_wheelchair_accessible")
  isActive               Boolean   @default(true) @map("is_active")
  totalDistanceKm        Float     @default(0) @map("total_distance_km")
  journeyCount           Int       @default(0) @map("journey_count")
  lastMaintenanceDate    DateTime? @map("last_maintenance_date")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  operator Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  journeys Journey[]

  @@index([operatorId])
  @@index([isActive])
  @@map("vehicles")
}

model Journey {
  id              String        @id @default(uuid()) @db.Uuid
  routeId         String        @map("route_id") @db.Uuid
  operatorId      String        @map("operator_id") @db.Uuid
  driverId        String        @map("driver_id") @db.Uuid
  vehicleId       String?       @map("vehicle_id") @db.Uuid
  busRegistration String        @map("bus_registration") @db.VarChar(20)
  departureTime   DateTime      @map("departure_time")
  arrivalTime     DateTime?     @map("arrival_time")
  totalSeats      Int           @map("total_seats")
  availableSeats  Int           @map("available_seats")
  price           Decimal       @db.Decimal(10, 2)
  status          JourneyStatus @default(SCHEDULED)
  trackingToken   String        @unique @map("tracking_token") @db.VarChar(64)
  createdAt       DateTime      @default(now()) @map("created_at")

  route    Route    @relation(fields: [routeId], references: [id], onDelete: Restrict)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  driver   Driver   @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  bookings  Booking[]
  gpsLogs   GPSLog[]
  alerts    SafetyAlert[]
  sosEvents SOSEvent[]
  detours   PlannedDetour[]

  @@index([routeId])
  @@index([operatorId])
  @@index([driverId])
  @@index([vehicleId])
  @@index([departureTime])
  @@index([status])
  @@index([status, departureTime])
  @@map("journeys")
}

model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  journeyId      String        @map("journey_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  seatNumber     Int?          @map("seat_number")
  reference      String        @unique @db.VarChar(20)
  paymentMethod  PaymentMethod @map("payment_method")
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  status         BookingStatus @default(PENDING)
  price          Decimal       @db.Decimal(10, 2)
  bookedVia      String        @default("WEB") @map("booked_via") @db.VarChar(20)
  passengerPhone String        @map("passenger_phone") @db.VarChar(20)
  passengerName  String        @map("passenger_name") @db.VarChar(100)
  qrCode         String?       @map("qr_code") @db.Text
  checkedInAt    DateTime?     @map("checked_in_at")
  cancelledAt    DateTime?     @map("cancelled_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating  Rating?

  @@index([journeyId])
  @@index([userId])
  @@index([reference])
  @@index([paymentStatus])
  @@index([paymentStatus, paymentMethod])
  @@index([status, createdAt])
  @@map("bookings")
}

model GPSLog {
  id        BigInt   @id @default(autoincrement())
  journeyId String   @map("journey_id") @db.Uuid
  lat       Decimal  @db.Decimal(10, 7)
  lng       Decimal  @db.Decimal(10, 7)
  speedKmh  Int      @map("speed_kmh")
  heading   Int
  accuracy  Decimal  @db.Decimal(6, 2)
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId, timestamp(sort: Desc)])
  @@map("gps_logs")
}

model SafetyAlert {
  id         String        @id @default(uuid()) @db.Uuid
  journeyId  String        @map("journey_id") @db.Uuid
  operatorId String        @map("operator_id") @db.Uuid
  alertType  AlertType     @map("alert_type")
  severity   AlertSeverity
  data       Json          @default("{}")
  resolved   Boolean       @default(false)
  resolvedAt DateTime?     @map("resolved_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  journey  Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([operatorId])
  @@index([alertType])
  @@index([resolved])
  @@map("safety_alerts")
}

model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  driverId  String   @map("driver_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  stars     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([userId])
  @@map("ratings")
}

model SOSEvent {
  id          String    @id @default(uuid()) @db.Uuid
  journeyId   String    @map("journey_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  phone       String    @db.VarChar(20)
  lat         Decimal?  @db.Decimal(10, 7)
  lng         Decimal?  @db.Decimal(10, 7)
  description String?   @db.Text
  status      SOSStatus @default(ACTIVE)
  resolved    Boolean   @default(false)
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([journeyId])
  @@index([resolved])
  @@index([status])
  @@map("sos_events")
}

model PlannedDetour {
  id           String   @id @default(cuid())
  journeyId    String   @map("journey_id") @db.Uuid
  reason       String   @db.Text
  startLat     Float
  startLng     Float
  endLat       Float
  endLng       Float
  radiusMeters Int      @default(2000) @map("radius_meters")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([isActive])
  @@map("planned_detours")
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique @db.VarChar(50)
  operatorId    String?   @map("operator_id") @db.Uuid
  operator      Operator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  discountType  String    @map("discount_type") @db.VarChar(20) // PERCENTAGE or FIXED
  discountValue Float     @map("discount_value")
  maxUses       Int       @default(100) @map("max_uses")
  currentUses   Int       @default(0) @map("current_uses")
  minBookingAmount Float? @map("min_booking_amount")
  validFrom     DateTime  @map("valid_from")
  validUntil    DateTime  @map("valid_until")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([code])
  @@index([operatorId])
  @@index([isActive])
  @@map("promo_codes")
}

model EmergencyContact {
  id           String    @id @default(cuid())
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String    @db.VarChar(100)
  phone        String    @db.VarChar(20)
  relationship String?   @db.VarChar(50)
  isVerified   Boolean   @default(false) @map("is_verified")
  verifiedAt   DateTime? @map("verified_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("emergency_contacts")
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique @map("user_id") @db.Uuid
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingConfirmation   Boolean  @default(true) @map("booking_confirmation")
  journeyReminder       Boolean  @default(true) @map("journey_reminder")
  safetyAlerts          Boolean  @default(true) @map("safety_alerts")
  sosAlerts             Boolean  @default(true) @map("sos_alerts") // Always true, read-only
  promotions            Boolean  @default(true)
  journeyUpdates        Boolean  @default(true) @map("journey_updates")
  deliveryMethod        String   @default("BOTH") @map("delivery_method") @db.VarChar(10) // SMS, PUSH, BOTH
  language              String   @default("en") @db.VarChar(5)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("notification_preferences")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  userRole     String?  @map("user_role")
  action       String   // LOGIN, LOGOUT, BOOKING_CREATE, BOOKING_CANCEL, PAYMENT_INITIATE, PAYMENT_COMPLETE, SOS_TRIGGER, SOS_RESOLVE, OPERATOR_SUSPEND, GPS_ACCESS, RTSA_ACTION, REGISTER, etc.
  resource     String   // The resource type (booking, journey, operator, user, etc.)
  resourceId   String?  @map("resource_id")
  details      Json?    // Additional context
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  previousHash String?  @map("previous_hash") // Hash of previous log entry for tamper evidence
  hash         String   // HMAC-SHA256 of this entry's data
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}
