# Database
DATABASE_URL=postgresql://zedpulse:zedpulse_dev_password@localhost:5432/zedpulse_db
REDIS_URL=redis://:zedpulse_redis_password@localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production
REFRESH_EXPIRES_IN=30d

# Africa's Talking (USSD + SMS)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=zedpulse
AT_USSD_CODE=*147#
AT_SENDER_ID=ZedPulse

# Mobile Money - Airtel
AIRTEL_MONEY_CLIENT_ID=your_airtel_client_id
AIRTEL_MONEY_CLIENT_SECRET=your_airtel_secret
AIRTEL_MONEY_BASE_URL=https://openapi.airtel.africa

# Mobile Money - MTN
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_key
MTN_MOMO_API_USER=your_mtn_api_user
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Mobile Money - Zamtel
ZAMTEL_KWACHA_API_KEY=your_zamtel_api_key
ZAMTEL_KWACHA_BASE_URL=https://api.zamtel.zm

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_3D_TILES_API_KEY=your_3d_tiles_api_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_3D_TILES_API_KEY=your_3d_tiles_api_key

# Application
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# RTSA (Government Integration)
RTSA_WEBHOOK_SECRET=your_rtsa_webhook_secret
RTSA_API_KEY=your_rtsa_integration_key

# Operations
OPS_PHONE=+260211244424

# Platform
PLATFORM_COMMISSION_RATE=0.05
CANCELLATION_FEE_RATE=0.10
SEAT_RESERVATION_TIMEOUT_MINUTES=10
