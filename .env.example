# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://twende:CHANGE_ME@localhost:5432/twende_db
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# Docker compose credentials (used by docker-compose.yml)
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# ─── Authentication (REQUIRED — app will not start without these) ─────────────
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=24h
REFRESH_EXPIRES_IN=30d

# ─── Security Secrets (REQUIRED) ─────────────────────────────────────────────
CSRF_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET_HERE
AUDIT_HMAC_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET_HERE
GPS_ENCRYPTION_SECRET=GENERATE_A_32_CHAR_SECRET_HERE_32B
QR_SIGNING_SECRET=GENERATE_A_64_CHAR_RANDOM_SECRET_HERE

# ─── Payment Webhook Secrets (REQUIRED for production) ───────────────────────
AIRTEL_WEBHOOK_SECRET=your_airtel_webhook_signing_secret
MTN_WEBHOOK_SECRET=your_mtn_webhook_signing_secret
ZAMTEL_WEBHOOK_SECRET=your_zamtel_webhook_signing_secret

# ─── Africa's Talking (USSD + SMS) ───────────────────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=twende
AT_USSD_CODE=*147#
AT_SENDER_ID=Twende

# ─── Mobile Money - Airtel ───────────────────────────────────────────────────
AIRTEL_MONEY_CLIENT_ID=your_airtel_client_id
AIRTEL_MONEY_CLIENT_SECRET=your_airtel_secret
AIRTEL_MONEY_BASE_URL=https://openapi.airtel.africa

# ─── Mobile Money - MTN ─────────────────────────────────────────────────────
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_key
MTN_MOMO_API_USER=your_mtn_api_user
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# ─── Mobile Money - Zamtel ───────────────────────────────────────────────────
ZAMTEL_KWACHA_API_KEY=your_zamtel_api_key
ZAMTEL_KWACHA_BASE_URL=https://api.zamtel.zm

# ─── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_3D_TILES_API_KEY=your_3d_tiles_api_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_3D_TILES_API_KEY=your_3d_tiles_api_key

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ─── RTSA (Government Integration) ──────────────────────────────────────────
RTSA_WEBHOOK_SECRET=your_rtsa_webhook_secret
RTSA_API_KEY=your_rtsa_integration_key
RTSA_ALERT_PHONE=+260211234567
EMERGENCY_PHONE=+260211999999
POLICE_PHONE=+260211911111

# ─── Operations ──────────────────────────────────────────────────────────────
OPS_PHONE=+260211244424

# ─── Platform ────────────────────────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.05
CANCELLATION_FEE_RATE=0.10
SEAT_RESERVATION_TIMEOUT_MINUTES=10
